# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_SHEETS_ID: The ID of the Google Sheet to store data in.
GOOGLE_SHEETS_ID="1_9K7TmzhSp5pbNJjUw7giomvf0gPU953KquKgpD6RZU"

# GOOGLE_SERVICE_ACCOUNT_KEY: The JSON key for the Google Service Account.
# This should be the entire JSON string from the service account key file.
GOOGLE_SERVICE_ACCOUNT_KEY='{}'

# GOOGLE_APPS_SCRIPT_URL: Alternative way to save to Sheets without a service account.
# Get this by deploying a Google Apps Script as a Web App.
GOOGLE_APPS_SCRIPT_URL="https://script.google.com/macros/s/AKfycbyJK4s_jKZhjYgjTKMTJV1_ME1cZGeHNddfm12f-tS5Qmeboxp4Yhwo6FYNsGIIK4QaqA/exec"
